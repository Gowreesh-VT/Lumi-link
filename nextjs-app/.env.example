# Server listening port (Next.js + Socket.io share this port)
PORT=3000

# Serial port paths — run `npm run list-ports` to find yours
# macOS: /dev/cu.usbserial-XXXX  or  /dev/cu.SLAB_USBtoUART0
# Linux: /dev/ttyUSB0  or  /dev/ttyACM0
TX_PORT=/dev/cu.usbserial-TX
RX_PORT=/dev/cu.usbserial-RX

# Must match Serial.begin() in the Arduino sketches
BAUD_RATE=115200

# MQTT scaffold (kept disabled by default)
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=lumi-link-local
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=lifi
MQTT_KEEPALIVE_SECONDS=60
MQTT_RECONNECT_MS=1500
MQTT_CONNECT_TIMEOUT_MS=30000
MQTT_CLEAN_SESSION=true
